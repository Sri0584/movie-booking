# -----------------------------
# Server Configuration
# -----------------------------
PORT=5000

# -----------------------------
# MongoDB Connection
# -----------------------------
#MONGO_URI=
# or for Atlas:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/movie_booking_db

# -----------------------------
# JWT Authentication
# -----------------------------
#JWT_SECRET=
JWT_EXPIRES_IN=1h

# -----------------------------
# CORS Configuration
# -----------------------------
CLIENT_URL=http://localhost:5173

# -----------------------------
# Cookie Settings
# -----------------------------
COOKIE_SECURE=false
COOKIE_SAMESITE=strict